#!/usr/bin/env bash
# .githooks/pre-commit — vendor-integrity + module-size gates.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# What this hook gates:
# 1. common/ source must match every consumer skill's scripts/_common/ tree
#    byte-for-byte. Direct edits to _common/, missed re-syncs, and stray
#    files (e.g., orphan .pyc) all fail.
# 2. Any quorum-review/scripts/quorum/ module exceeding the hard LoC cap
#    without an explicit waiver fails.
#
# Both gates are reversible: just fix the underlying problem and re-stage.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- Gate 1: vendored _common/ trees must match source ---------------------
if [[ -d common/common ]]; then
  if ! python3 common/scripts/sync_common.py --check; then
    echo
    echo "pre-commit: vendor-integrity check failed."
    echo "Run \`python3 common/scripts/sync_common.py\`, review the diff, and re-stage."
    exit 1
  fi
fi

# --- Gate 2: hard module-size cap across both skills' scripts/ trees ----------
# check_module_size.py recurses (rglob), so each dir covers its top-level scripts,
# the vendored _common/ tree, the quorum/ package, and the split tests/ modules.
# Accumulate status across dirs — never `|| true`, which would discard the
# hard-cap exit code and let a violation pass silently.
size_rc=0
for d in quorum-review/scripts peer-plan-review/scripts; do
  [[ -d $d ]] || continue
  python3 common/scripts/check_module_size.py "$d" || size_rc=1
done
if [[ $size_rc -ne 0 ]]; then
  echo
  echo "pre-commit: module-size hard cap exceeded."
  echo "Split the oversized module OR add an explicit waiver:"
  echo "    # WAIVER: module-size <reason>"
  echo "in the first 20 lines of the file."
  exit 1
fi

# --- Gate 3: Ruff lint + format on staged Python -----------------------------
if ! command -v ruff >/dev/null 2>&1; then
  echo "pre-commit: ruff not found. Install the pinned version: pip install ruff==0.15.6"
  exit 1
fi
# Soft version check — determinism depends on the pin. Warn (don't block) on drift
# so a minor local bump doesn't halt commits, but the mismatch is visible.
want_ruff=0.15.6
have_ruff=$(ruff --version 2>/dev/null | awk '{print $2}')
if [[ "$have_ruff" != "$want_ruff" ]]; then
  echo "pre-commit: warning — ruff $have_ruff != pinned $want_ruff; results may differ. See AGENTS.md ## Dev tooling."
fi
# Guard first so xargs never runs on empty input — this is what keeps it portable:
# GNU xargs would run ruff with zero paths (linting the whole tree) on empty input
# unless given -r, but BSD/macOS xargs rejects -r. The `grep -q .` guard sidesteps
# the divergence entirely. The -z/-0 pair keeps paths with spaces/newlines intact.
# --force-exclude honors extend-exclude/.gitignore for the explicit paths. This
# lints the working-tree copy of staged files (not the staged blob), matching the
# repo's existing gates; partial stages are the committer's responsibility.
if git diff --cached --name-only --diff-filter=ACMR -- '*.py' | grep -q .; then
  git diff --cached -z --name-only --diff-filter=ACMR -- '*.py' \
    | xargs -0 ruff check --force-exclude || {
      echo "pre-commit: ruff check failed. Fix, or run: ruff check --fix"; exit 1; }
  git diff --cached -z --name-only --diff-filter=ACMR -- '*.py' \
    | xargs -0 ruff format --check --force-exclude || {
      echo "pre-commit: formatting drift. Run: ruff format"; exit 1; }
fi

exit 0
